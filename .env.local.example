# ── Stellar ───────────────────────────────────────────────────────────────────
# Your deployed Soroban contract address (set after: stellar contract deploy)
NEXT_PUBLIC_CONTRACT_ID=CAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAD2KM

# Network: testnet | mainnet
NEXT_PUBLIC_NETWORK=testnet

# RPC endpoints (defaults shown — override if using a private RPC)
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
